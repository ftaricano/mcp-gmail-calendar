# Google OAuth2 Configuration
# Create a project at https://console.cloud.google.com/
# Enable Gmail API and Google Calendar API
# Create OAuth2 credentials (Desktop application type)

# Path to your Google OAuth2 credentials JSON file
GOOGLE_CREDENTIALS_PATH=./credentials.json

# Port for OAuth callback (default: 3000)
OAUTH_CALLBACK_PORT=3000

# Tokens storage path (for multi-account support)
TOKENS_PATH=./tokens

# Cache settings
CACHE_TTL=300  # Cache TTL in seconds (default: 5 minutes)
CACHE_CHECK_PERIOD=60  # Cache check period in seconds

# Email settings
MAX_EMAIL_RESULTS=50  # Maximum emails to fetch per request
MAX_ATTACHMENT_SIZE=25000000  # Maximum attachment size in bytes (25MB)

# Calendar settings
MAX_CALENDAR_EVENTS=100  # Maximum calendar events to fetch per request
DEFAULT_CALENDAR_TIMEZONE=America/New_York

# Logging
LOG_LEVEL=info  # debug, info, warn, error
LOG_FILE_PATH=./logs/mcp-gmail-calendar.log

# Security
ENABLE_HTML_SANITIZATION=true
ALLOWED_ATTACHMENT_TYPES=pdf,doc,docx,xls,xlsx,ppt,pptx,txt,csv,jpg,jpeg,png,gif,zip

# Template settings
TEMPLATE_PATH=./templates
DEFAULT_EMAIL_THEME=professional  # professional, modern, minimal, corporate