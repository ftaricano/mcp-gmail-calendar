# Google OAuth2 Configuration
# Create a project at https://console.cloud.google.com/
# Enable Gmail API and Google Calendar API
# Create OAuth2 credentials as a Desktop application.

# Path to your Google OAuth2 credentials JSON file.
GOOGLE_CREDENTIALS_PATH=./credentials.json

# Port for OAuth callback (default: 3000).
OAUTH_CALLBACK_PORT=3000

# Optional: override CLI config/state/tokens directory.
# Default: ~/.config/gws
GWS_CONFIG_DIR=~/.config/gws

# Tokens storage path for the legacy MCP server.
# CLI account state uses GWS_CONFIG_DIR/tokens unless overridden by the auth manager environment.
TOKENS_PATH=~/.config/gws/tokens

# Cache settings.
CACHE_TTL=300
CACHE_CHECK_PERIOD=60

# Email settings.
MAX_EMAIL_RESULTS=50
MAX_ATTACHMENT_SIZE=25000000
ATTACHMENT_DOWNLOAD_DIR=./attachments/downloads

# Calendar settings.
MAX_CALENDAR_EVENTS=100
DEFAULT_CALENDAR_TIMEZONE=America/Sao_Paulo

# Logging.
LOG_LEVEL=info
LOG_FILE_PATH=./logs/mcp-gmail-calendar.log

# Security.
ENABLE_HTML_SANITIZATION=true
ALLOWED_ATTACHMENT_TYPES=pdf,doc,docx,xls,xlsx,ppt,pptx,txt,csv,jpg,jpeg,png,gif,zip

# Template settings.
TEMPLATE_PATH=./templates
DEFAULT_EMAIL_THEME=professional
