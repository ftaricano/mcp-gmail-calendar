{
  "name": "@mcp/gmail-calendar",
  "version": "1.0.0",
  "description": "MCP server for Gmail and Google Calendar workflows with multi-account OAuth support.",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "jest --passWithNoTests",
    "lint": "eslint .",
    "format": "prettier --write src/**/*.ts",
    "setup": "node -e \"console.log('Manual setup only: copy .env.example to .env and follow README.md')\"",
    "google-setup": "node -e \"console.log('Manual Google setup only: configure OAuth credentials as documented in README.md')\"",
    "clean": "rm -rf dist/ logs/ tokens/ attachments/",
    "postinstall": "npm run build"
  },
  "keywords": [
    "mcp",
    "gmail",
    "google-calendar",
    "email",
    "calendar",
    "google-workspace"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "dayjs": "^1.11.13",
    "dotenv": "^16.4.7",
    "google-auth-library": "^10.6.2",
    "googleapis": "^171.4.0",
    "handlebars": "^4.7.9",
    "html-to-text": "^9.0.5",
    "juice": "^11.1.1",
    "mime-types": "^2.1.35",
    "node-cache": "^5.1.2",
    "sanitize-html": "^2.14.0",
    "winston": "^3.17.0",
    "zod": "^3.24.1"
  },
  "overrides": {
    "jws": "4.0.1",
    "node-forge": "1.4.0",
    "undici": "^6.24.0"
  },
  "devDependencies": {
    "@types/html-to-text": "^9.0.4",
    "@types/jest": "^29.5.14",
    "@types/mime-types": "^2.1.4",
    "@types/node": "^22.10.5",
    "@types/sanitize-html": "^2.14.0",
    "@typescript-eslint/eslint-plugin": "^8.18.2",
    "@typescript-eslint/parser": "^8.18.2",
    "eslint": "^9.17.0",
    "jest": "^29.7.0",
    "prettier": "^3.4.2",
    "ts-jest": "^29.2.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
